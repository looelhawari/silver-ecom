APP_NAME="Fidda Silver"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=Africa/Cairo

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_EG

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database
# Local dev defaults to SQLite (zero-config). PRODUCTION TARGET IS MYSQL:
# set DB_CONNECTION=mysql and fill the values below.
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=fidda_silver
# DB_USERNAME=fidda
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
# 'local' (storage/app) for dev; switch to 's3' or a public disk in production.
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="care@fidda-silver.test"
MAIL_FROM_NAME="${APP_NAME}"

# Brevo transactional SMTP (production example; keep real secrets in .env only)
# MAIL_MAILER=smtp
# MAIL_SCHEME=null
# MAIL_HOST=smtp-relay.brevo.com
# MAIL_PORT=587
# MAIL_USERNAME=<brevo-smtp-login>
# MAIL_PASSWORD=<brevo-smtp-key>
# MAIL_FROM_ADDRESS=<verified-sender@your-domain.com>

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Frontend origin (Sanctum stateful domains, CORS, tracking links, reset-password URL)
FRONTEND_URL=http://localhost:3000
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
# Comma-separated allowed CORS origins (defaults to FRONTEND_URL). Set for production.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Storefront (white-label config; defaults live in config/white_label.php) --
STORE_NAME="Fidda Silver"
STORE_BUSINESS_TYPE=jewelry
STORE_SLOGAN="Egyptian, Italian & Turkish silver — and bespoke pieces made for you."
STORE_CURRENCY=EGP
STORE_LOCALE=en
STORE_DIRECTION=ltr
STORE_THEME_PRESET=silver-luxury
STORE_PHONE="+20 100 000 0000"
STORE_WHATSAPP="+20 100 000 0000"
STORE_EMAIL=care@fidda-silver.test
STORE_ADDRESS="Cairo, Egypt"
STORE_WORKING_HOURS="Sat–Thu 11:00–21:00"
STORE_INSTAGRAM_URL=
STORE_FACEBOOK_URL=
STORE_TIKTOK_URL=
STORE_X_URL=
STORE_SEO_TITLE="Fidda Silver — Fine & Custom Silver Jewelry"
STORE_SEO_DESCRIPTION="Shop Egyptian, Italian, Turkish and local silver jewelry, or request a custom-made piece."
STORE_SEO_KEYWORDS="silver jewelry,egyptian silver,italian silver,turkish silver,custom silver"

# --- Initial admin (seeded super-admin for the Filament panel) ------------------
# CHANGE THESE before any real deployment.
ADMIN_NAME="Store Owner"
ADMIN_EMAIL=admin@fidda-silver.test
ADMIN_PASSWORD=password
